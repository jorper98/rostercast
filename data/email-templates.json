[
  {
    "id": 1,
    "name": "Welcome Template",
    "subject": "Welcome to the group, {{first_name}}!",
    "body": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head><body style=\"margin:0; padding:0; background-color:#f5f5f5; font-family:Arial, Helvetica, sans-serif;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f5f5f5;\"><tr><td align=\"center\" style=\"padding:40px 15px;\"><table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px; width:100%;\"><tr><td style=\"background-color:#2c3e50; border-radius:12px 12px 0 0; padding:40px 30px; text-align:center;\"><h1 style=\"margin:0; color:#ffffff; font-size:28px; font-weight:bold; letter-spacing:0.5px;\">Welcome Aboard!</h1></td></tr><tr><td style=\"background-color:#ffffff; padding:35px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><p style=\"margin:0 0 20px 0; font-size:16px; color:#333333; line-height:1.6;\">Dear {{first_name}},</p><p style=\"margin:0 0 20px 0; font-size:16px; color:#333333; line-height:1.6;\">We're thrilled to have you join our group. Your membership is now active and you'll start receiving updates about upcoming events, news, and activities.</p><p style=\"margin:0 0 25px 0; font-size:16px; color:#333333; line-height:1.6;\">If you have any questions, feel free to reach out anytime. We're glad you're here!</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 auto;\"><tr><td align=\"center\" style=\"background-color:#3498db; border-radius:6px; padding:12px 30px; color:#000000;\"><a href=\"#\" style=\"color:#000000; text-decoration:none; font-size:15px; font-weight:bold; display:inline-block;\">Get Started</a></td></tr></table><p style=\"margin:0 0 15px 0; line-height:1.6; font-size:16px; color:#333333;\">&nbsp;</p><p style=\"margin:0 0 15px 0; line-height:1.6; font-size:16px; color:#333333;\">&nbsp;</p></td></tr><tr><td style=\"height:40px; background-color:#ffffff; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\">&nbsp;</td></tr><tr><td style=\"background-color:#2c3e50; border-radius:0 0 12px 12px; padding:20px 30px; text-align:center;\"><p style=\"margin:0 0 4px 0; font-size:13px; color:#ffffff;\">Your Friendly Group Leader</p><p style=\"margin:0; font-size:12px; color:#bdc3c7;\"><a href=\"https://yourwebsite.com\" style=\"color:#3498db; text-decoration:underline;\">https://yourwebsite.com</a></p></td></tr></table></td></tr></table></body></html>"
  },
  {
    "id": 2,
    "name": "Group Updates and News",
    "subject": "Latest Group News & Updates",
    "body": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head><body style=\"margin:0; padding:0; background-color:#f5f5f5; font-family:Arial, Helvetica, sans-serif;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f5f5f5;\"><tr><td align=\"center\" style=\"padding:40px 15px;\"><table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px; width:100%;\"><tr><td style=\"background-color:#2c3e50; border-radius:12px 12px 0 0; padding:30px; text-align:center;\"><h1 style=\"margin:0; color:#ffffff; font-size:24px; font-weight:bold;\">Group Updates &amp; News</h1><p style=\"margin:8px 0 0 0; color:#bdc3c7; font-size:14px;\">Stay informed with the latest from our community</p></td></tr><tr><td style=\"background-color:#ffffff; padding:30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><p style=\"margin:0 0 20px 0; font-size:16px; color:#333333; line-height:1.6;\">Hi {{first_name}},</p><p style=\"margin:0 0 25px 0; font-size:16px; color:#333333; line-height:1.6;\">Here's what's new in our group. We've got some exciting developments to share with you!</p></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden; margin-bottom:15px;\"><tr><td style=\"background-color:#3498db; padding:12px 20px;\"><h2 style=\"margin:0; color:#ffffff; font-size:16px; font-weight:bold;\">New Meeting Schedule</h2></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">Starting next month, our regular meetings will move to the second Thursday of each month at 7:00 PM. The location remains the same &mdash; Community Center, Room 204. Please mark your calendars!</p><a href=\"#\" style=\"color:#3498db; font-size:14px; text-decoration:none; font-weight:bold;\">View full schedule &rarr;</a></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden; margin-bottom:15px;\"><tr><td style=\"background-color:#27ae60; padding:12px 20px;\"><h2 style=\"margin:0; color:#ffffff; font-size:16px; font-weight:bold;\">Membership Milestone</h2></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">We're excited to announce that our group has surpassed 100 active members! Thank you to everyone who has helped us grow. To celebrate, we'll be hosting a special appreciation event next quarter &mdash; details to follow.</p><a href=\"#\" style=\"color:#27ae60; font-size:14px; text-decoration:none; font-weight:bold;\">Learn more &rarr;</a></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden; margin-bottom:15px;\"><tr><td style=\"background-color:#f39c12; padding:12px 20px;\"><h2 style=\"margin:0; color:#ffffff; font-size:16px; font-weight:bold;\">Volunteer Opportunities</h2></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">We're looking for volunteers to help with our upcoming community outreach program. Roles include event setup, registration desk, and social media support. If you're interested in lending a hand, sign up through the member portal or reply to this email.</p><a href=\"#\" style=\"color:#f39c12; font-size:14px; text-decoration:none; font-weight:bold;\">Sign up to volunteer &rarr;</a></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden; margin-bottom:15px;\"><tr><td style=\"background-color:#8e44ad; padding:12px 20px;\"><h2 style=\"margin:0; color:#ffffff; font-size:16px; font-weight:bold;\">Member Spotlight</h2></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">This month we'd like to recognize <strong>{{featured_member}}</strong> for their outstanding contributions to the group. From organizing our annual fundraiser to mentoring new members, their dedication has been truly inspiring. Thank you for making a difference!</p></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden; margin-bottom:15px;\"><tr><td style=\"background-color:#e74c3c; padding:12px 20px;\"><h2 style=\"margin:0; color:#ffffff; font-size:16px; font-weight:bold;\">Important: Dues Renewal</h2></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">Annual membership dues are due by <strong>{{due_date}}</strong>. Renewal helps us keep the group running and fund our activities. You can renew online through the member portal or by contacting the treasurer. Early renewal helps us plan ahead &mdash; thank you!</p><a href=\"#\" style=\"color:#e74c3c; font-size:14px; text-decoration:none; font-weight:bold;\">Renew now &rarr;</a></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:15px 30px 15px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8; text-align:center;\"><p style=\"margin:0; font-size:14px; color:#666666; line-height:1.6;\">That's all for now. Stay tuned for more updates!</p><p style=\"margin:0 0 15px 0; line-height:1.6; font-size:14px; color:#333333;\">&nbsp;</p><p style=\"margin:0 0 15px 0; line-height:1.6; font-size:14px; color:#333333;\">&nbsp;</p></td></tr><tr><td style=\"height:40px; background-color:#ffffff; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\">&nbsp;</td></tr><tr><td style=\"background-color:#2c3e50; border-radius:0 0 12px 12px; padding:20px 30px; text-align:center;\"><p style=\"margin:0 0 4px 0; font-size:13px; color:#ffffff;\">Your Friendly Group Leader</p><p style=\"margin:0; font-size:12px; color:#bdc3c7;\"><a href=\"https://yourwebsite.com\" style=\"color:#3498db; text-decoration:underline;\">https://yourwebsite.com</a></p></td></tr></table></td></tr></table></body></html>"
  },
  {
    "id": 3,
    "name": "Event Announcement",
    "subject": "Upcoming Event: {{event_name}}",
    "body": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head><body style=\"margin:0; padding:0; background-color:#f5f5f5; font-family:Arial, Helvetica, sans-serif;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f5f5f5;\"><tr><td align=\"center\" style=\"padding:40px 15px;\"><table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px; width:100%;\"><tr><td style=\"background-color:#e74c3c; border-radius:12px 12px 0 0; padding:35px 30px; text-align:center;\"><p style=\"margin:0 0 8px 0; color:#f9e4e1; font-size:14px; text-transform:uppercase; letter-spacing:2px; font-weight:bold;\">You're Invited</p><h1 style=\"margin:0; color:#ffffff; font-size:26px; font-weight:bold;\">{{event_name}}</h1></td></tr><tr><td style=\"background-color:#ffffff; padding:30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><p style=\"margin:0 0 20px 0; font-size:16px; color:#333333; line-height:1.6;\">Hi {{first_name}},</p><p style=\"margin:0 0 25px 0; font-size:16px; color:#333333; line-height:1.6;\">We have an exciting event coming up and we'd love for you to join us! Here are all the details:</p></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 30px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:2px solid #3498db; border-radius:8px; overflow:hidden;\"><tr><td style=\"background-color:#f0f8ff; padding:20px; border-bottom:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"width:60px; vertical-align:top; text-align:center; padding-right:15px;\"><div style=\"background-color:#3498db; color:#ffffff; font-size:11px; font-weight:bold; text-transform:uppercase; padding:4px 8px; border-radius:4px; text-align:center;\">Date</div></td><td style=\"font-size:15px; color:#333333; font-weight:bold; vertical-align:middle;\">{{event_date}}</td></tr></table></td></tr><tr><td style=\"padding:20px; border-bottom:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"width:60px; vertical-align:top; text-align:center; padding-right:15px;\"><div style=\"background-color:#27ae60; color:#ffffff; font-size:11px; font-weight:bold; text-transform:uppercase; padding:4px 8px; border-radius:4px; text-align:center;\">Time</div></td><td style=\"font-size:15px; color:#333333; font-weight:bold; vertical-align:middle;\">{{event_time}}</td></tr></table></td></tr><tr><td style=\"padding:20px; border-bottom:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"width:60px; vertical-align:top; text-align:center; padding-right:15px;\"><div style=\"background-color:#f39c12; color:#ffffff; font-size:11px; font-weight:bold; text-transform:uppercase; padding:4px 8px; border-radius:4px; text-align:center;\">Place</div></td><td style=\"font-size:15px; color:#333333; font-weight:bold; vertical-align:middle;\">{{event_location}}</td></tr></table></td></tr><tr><td style=\"padding:20px; background-color:#f9f9f9;\"><p style=\"margin:0 0 8px 0; font-size:14px; color:#333333; line-height:1.6;\"><strong>Cost:</strong> {{event_cost}}</p><p style=\"margin:0; font-size:14px; color:#333333; line-height:1.6;\"><strong>Dress Code:</strong> {{event_dress_code}}</p></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 20px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden;\"><tr><td style=\"background-color:#f8f9fa; padding:15px 20px; border-bottom:1px solid #e8e8e8;\"><h3 style=\"margin:0; font-size:15px; color:#2c3e50;\">Event Description</h3></td></tr><tr><td style=\"padding:20px;\"><p style=\"margin:0 0 10px 0; font-size:14px; color:#333333; line-height:1.6;\">{{event_description}}</p><p style=\"margin:0; font-size:14px; color:#333333; line-height:1.6;\">This is a great opportunity to connect with fellow members, learn something new, and have fun together. Whether you're a longtime member or just joined, everyone is welcome!</p></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 20px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden;\"><tr><td style=\"background-color:#f8f9fa; padding:15px 20px; border-bottom:1px solid #e8e8e8;\"><h3 style=\"margin:0; font-size:15px; color:#2c3e50;\">What to Bring</h3></td></tr><tr><td style=\"padding:20px;\"><ul style=\"margin:0; padding:0 0 0 20px; font-size:14px; color:#333333; line-height:1.8;\"><li>{{item_to_bring_1}}</li><li>{{item_to_bring_2}}</li><li>{{item_to_bring_3}}</li></ul></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 25px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8; border-radius:8px; overflow:hidden;\"><tr><td style=\"background-color:#f8f9fa; padding:15px 20px; border-bottom:1px solid #e8e8e8;\"><h3 style=\"margin:0; font-size:15px; color:#2c3e50;\">Agenda</h3></td></tr><tr><td style=\"padding:0;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:12px 20px; border-bottom:1px solid #f0f0f0; font-size:14px; color:#333333;\"><strong>{{agenda_time_1}}</strong> &mdash; {{agenda_item_1}}</td></tr><tr><td style=\"padding:12px 20px; border-bottom:1px solid #f0f0f0; font-size:14px; color:#333333;\"><strong>{{agenda_time_2}}</strong> &mdash; {{agenda_item_2}}</td></tr><tr><td style=\"padding:12px 20px; border-bottom:1px solid #f0f0f0; font-size:14px; color:#333333;\"><strong>{{agenda_time_3}}</strong> &mdash; {{agenda_item_3}}</td></tr><tr><td style=\"padding:12px 20px; font-size:14px; color:#333333;\"><strong>{{agenda_time_4}}</strong> &mdash; {{agenda_item_4}}</td></tr></table></td></tr></table></td></tr><tr><td style=\"background-color:#ffffff; padding:0 30px 25px 30px; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 auto; width:100%;\"><tr><td align=\"center\" style=\"padding:15px 0 10px 0;\"><p style=\"margin:0 0 5px 0; font-size:14px; color:#666666;\">Please RSVP by <strong>{{rsvp_deadline}}</strong></p></td></tr><tr><td align=\"center\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"background-color:#3498db; border-radius:6px; padding:12px 30px; color:#000000;\"><a href=\"{{rsvp_link}}\" style=\"color:#000000; text-decoration:none; font-size:15px; font-weight:bold; display:inline-block;\">RSVP Now</a></td></tr></table></td></tr></table></td></tr><tr><td style=\"height:40px; background-color:#ffffff; border-left:1px solid #e8e8e8; border-right:1px solid #e8e8e8;\">&nbsp;</td></tr><tr><td style=\"background-color:#2c3e50; border-radius:0 0 12px 12px; padding:20px 30px; text-align:center;\"><p style=\"margin:0 0 4px 0; font-size:13px; color:#ffffff;\">Your Friendly Group Leader</p><p style=\"margin:0; font-size:12px; color:#bdc3c7;\"><a href=\"https://yourwebsite.com\" style=\"color:#3498db; text-decoration:underline;\">https://yourwebsite.com</a></p></td></tr></table></td></tr></table></body></html>"
  }
]
