# RosterCast Application - Public Version Environment Configuration
# Copy this file to .env and fill in production values.
# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3032
NODE_ENV=production

# =============================================================================
# ADMIN MAINTENANCE ACCESS
# =============================================================================
# Set a strong admin password. USER_PASSWORD must remain unset for public
# read-only mode.
ADMIN_PASSWORD=change-this-admin-password
# USER_PASSWORD=

# =============================================================================
# OPTIONAL GEOCODING
# =============================================================================
# GOOGLE_API_KEY=your_google_api_key
# OPENCAGE_API_KEY=your_opencage_api_key
